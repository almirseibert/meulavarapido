# URL da API (backend Node no Easypanel). Em DEV use o IP da sua máquina na rede,
# nunca "localhost" (o app no celular não acessa o localhost do PC).
# Ex.: http://192.168.0.10:3000  ou  https://api.seudominio.com
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000

# --- AdMob (anúncios da versão grátis) ---
# Deixe vazio para usar os IDs de TESTE oficiais do Google (recomendado em DEV).
# Em produção, cole o ID da sua unidade de "Recompensado".
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=

# --- RevenueCat (assinatura premium) ---
# Chaves públicas do projeto no RevenueCat (Project settings > API keys).
EXPO_PUBLIC_RC_ANDROID_KEY=
EXPO_PUBLIC_RC_IOS_KEY=
