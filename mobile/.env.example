# URL da API (backend Node no Easypanel). Em DEV use o IP da sua máquina na rede,
# nunca "localhost" (o app no celular não acessa o localhost do PC).
# Ex.: http://192.168.0.10:3000  ou  https://api.seudominio.com
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000

# --- Firebase Phone Auth (verificação de telefone no cadastro) ---
# A config do Firebase vem dos arquivos nativos google-services.json (Android) e
# GoogleService-Info.plist (iOS), referenciados em app.json — não há env aqui.
# Sem esses arquivos + credenciais no backend, o cadastro roda em modo dev
# (telefone não verificado). Exige dev build (não funciona no Expo Go).

# --- Ambiente ---
# "production" bloqueia ativação manual de premium (obrigatório na build de loja).
# "development" permite ativar premium manualmente via backend (apenas para testes).
EXPO_PUBLIC_ENV=development

# --- RevenueCat (assinatura premium) ---
# Chaves públicas do projeto no RevenueCat (Project settings > API keys).
# Obrigatório para builds de produção; sem elas somente funciona em modo development.
EXPO_PUBLIC_RC_ANDROID_KEY=
EXPO_PUBLIC_RC_IOS_KEY=
