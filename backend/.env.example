# ===== Banco de dados PostgreSQL (Easypanel / Hostinger VPS) =====
# No Easypanel, ao criar o serviço Postgres, use os dados internos do serviço.
DB_HOST=meu-lava-rapido-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=troque-esta-senha
DB_NAME=meulavarapido
# Alternativa: string única (tem prioridade se preenchida)
# DATABASE_URL=postgres://postgres:senha@host:5432/meulavarapido
DB_SSL=false

# ===== Autenticação =====
# Gere uma chave longa e aleatória (ex.: openssl rand -hex 32)
JWT_SECRET=troque-por-uma-chave-secreta-bem-longa-e-aleatoria
JWT_EXPIRES_IN=30d

# ===== Servidor =====
PORT=3000

# ===== Validação de assinatura (opcional, fase 2) =====
# Segredo compartilhado para o webhook do RevenueCat.
REVENUECAT_WEBHOOK_SECRET=
